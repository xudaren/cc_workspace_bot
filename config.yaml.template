apps:
  - id: "product-assistant"
    feishu_app_id: "cli_xxx"
    feishu_app_secret: "xxx"
    feishu_verification_token: "xxx"
    feishu_encrypt_key: ""
    workspace_dir: "./workspaces/product-assistant"
    allowed_chats: []
    claude:
      permission_mode: "acceptEdits"
      allowed_tools:
        - "Bash"
        - "Read"
        - "Edit"
        - "Write"
      # provider: "bailian"        # 覆盖默认供应商（可选）
      # model: "kimi-k2.5"         # 覆盖该供应商的默认模型（可选）

  # - id: "code-review"
  #   feishu_app_id: "cli_yyy"
  #   feishu_app_secret: "yyy"
  #   feishu_verification_token: "yyy"
  #   feishu_encrypt_key: ""
  #   workspace_dir: "./workspaces/code-review"
  #   allowed_chats:
  #     - "oc_abc123"
  #   claude:
  #     permission_mode: "acceptEdits"
  #     provider: "anthropic"
  #     model: "opus"
  #     allowed_tools:
  #       - "Read"
  #       - "Bash"

server:
  port: 8080

claude:
  timeout_minutes: 5
  max_turns: 20
  default_provider: "anthropic"       # 默认供应商，必须对应 providers 中的某个 key
  providers:
    anthropic:                        # Anthropic 原生服务（不需要 base_url 和 auth_token）
      model: "sonnet"                 # 默认模型：别名(sonnet/opus/haiku)或完整ID(claude-sonnet-4-6)
    # bailian:                        # 阿里云百炼平台
    #   base_url: "https://coding.dashscope.aliyuncs.com/apps/anthropic"
    #   auth_token: "sk-your-dashscope-api-key"
    #   model: "qwen-plus"            # 百炼默认模型

session:
  worker_idle_timeout_minutes: 30

cleanup:
  attachments_retention_days: 7
  attachments_max_days: 30
  schedule: "0 2 * * *"
